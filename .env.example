# Copy to .env.local and fill in the values.

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase (Database) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Supabase Edge Function (process-message) ─────────────────────────────────
# The inbound WhatsApp AI pipeline runs in this Edge Function. The Twilio
# webhook acks Twilio in <500ms, then fires a single authenticated fetch here.
#
# SUPABASE_EDGE_FUNCTION_URL: full URL of the deployed function, e.g.
#   https://<project-ref>.supabase.co/functions/v1/process-message
# EDGE_FUNCTION_SECRET: shared secret guarding the function. This is a PAIRED
#   secret — it MUST exactly match the value set on the deployed function via
#   `supabase secrets set EDGE_FUNCTION_SECRET=...`. If they drift, the function
#   returns 401 and no replies are sent.
SUPABASE_EDGE_FUNCTION_URL=
EDGE_FUNCTION_SECRET=

# ── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# ── AI Providers ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Twilio ───────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WEBHOOK_URL=

# ── Upstash Redis ────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Resend ───────────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_WEBHOOK_URL=

# ── Calendly ─────────────────────────────────────────────────────────────────
CALENDLY_API_KEY=
CALENDLY_WEBHOOK_SECRET=

# ── Google Calendar ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Paystack ─────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
