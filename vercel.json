{
  "functions": {
    "src/app/api/webhook/twilio/route.ts": {
      "maxDuration": 10
    },
    "src/app/api/conversations/reply/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/followups/process/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/reminders/process/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/followups/process",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/followups/stale-conversations",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/reminders/process",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cleanup/rate-limits",
      "schedule": "0 3 * * *"
    }
  ]
}
